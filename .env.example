# Copy this file to `.env.local` and fill in a Blockfrost project id to make
# Cardano L1 data live. Without it, the app serves the deterministic mock feed.
#
# Get a free project id at https://blockfrost.io (one per network).

# BLOCKFROST_PROJECT_ID=mainnetXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Which network the project id belongs to: mainnet | preprod | preview
# BLOCKFROST_NETWORK=mainnet
